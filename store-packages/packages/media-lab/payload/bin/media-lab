#!/usr/bin/env python3
import queue
import re
import subprocess
import threading
from pathlib import Path
import tkinter as tk
from tkinter import filedialog, messagebox, ttk

TIME_RE = re.compile(r"time=(\d+:\d+:\d+(?:\.\d+)?)")

PRESETS = {
    "MP4 (H.264 Balanced)": ["-c:v", "libx264", "-preset", "medium", "-crf", "23", "-c:a", "aac", "-b:a", "192k"],
    "WebM (VP9 Small)": ["-c:v", "libvpx-vp9", "-b:v", "0", "-crf", "33", "-c:a", "libopus", "-b:a", "128k"],
    "MP3 (320k Audio)": ["-vn", "-c:a", "libmp3lame", "-b:a", "320k"],
    "GIF (Looping Clip)": ["-vf", "fps=14,scale=960:-1:flags=lanczos", "-loop", "0"],
}


def parse_timestamp(value: str) -> float:
    parts = value.split(":")
    if len(parts) != 3:
        return 0.0
    hours = float(parts[0])
    minutes = float(parts[1])
    seconds = float(parts[2])
    return hours * 3600.0 + minutes * 60.0 + seconds


def ffprobe_duration(file_path: str) -> float:
    cmd = [
        "ffprobe",
        "-v",
        "error",
        "-show_entries",
        "format=duration",
        "-of",
        "default=noprint_wrappers=1:nokey=1",
        file_path,
    ]
    try:
        out = subprocess.check_output(cmd, text=True, stderr=subprocess.DEVNULL).strip()
        return float(out)
    except Exception:
        return 0.0


class MediaLab(tk.Tk):
    def __init__(self) -> None:
        super().__init__()
        self.title("Media Lab")
        self.geometry("1080x720")
        self.minsize(920, 620)
        self.configure(bg="#0a162a")

        self.proc: subprocess.Popen | None = None
        self.worker: threading.Thread | None = None
        self.log_queue: queue.Queue[tuple[str, str]] = queue.Queue()
        self.total_duration = 0.0

        self.input_var = tk.StringVar()
        self.output_var = tk.StringVar()
        self.preset_var = tk.StringVar(value=list(PRESETS.keys())[0])
        self.start_var = tk.StringVar()
        self.length_var = tk.StringVar()
        self.status_var = tk.StringVar(value="Ready")
        self.progress_var = tk.DoubleVar(value=0.0)

        self.setup_style()
        self.build_ui()
        self.after(120, self.poll_queue)

    def setup_style(self) -> None:
        self.style = ttk.Style(self)
        try:
            self.style.theme_use("clam")
        except tk.TclError:
            pass
        self.style.configure(".", background="#0a162a", foreground="#dbeafe", font=("DejaVu Sans", 10))
        self.style.configure("Header.TLabel", font=("DejaVu Sans", 15, "bold"))
        self.style.configure("Muted.TLabel", foreground="#8ea6cb")
        self.style.configure("TButton", padding=(10, 6))

    def build_ui(self) -> None:
        self.grid_columnconfigure(0, weight=1)
        self.grid_rowconfigure(1, weight=1)

        top = ttk.Frame(self)
        top.grid(row=0, column=0, sticky="ew", padx=12, pady=(12, 8))
        top.grid_columnconfigure(1, weight=1)
        ttk.Label(top, text="Media Lab", style="Header.TLabel").grid(row=0, column=0, sticky="w", padx=(8, 10))
        ttk.Label(top, text="ffmpeg conversion studio", style="Muted.TLabel").grid(row=0, column=1, sticky="w")

        form = ttk.Frame(self)
        form.grid(row=1, column=0, sticky="nsew", padx=12, pady=8)
        form.grid_columnconfigure(1, weight=1)
        form.grid_rowconfigure(6, weight=1)

        ttk.Label(form, text="Input File", style="Muted.TLabel").grid(row=0, column=0, sticky="w", padx=8, pady=4)
        ttk.Entry(form, textvariable=self.input_var).grid(row=0, column=1, sticky="ew", padx=8, pady=4)
        ttk.Button(form, text="Browse", command=self.choose_input).grid(row=0, column=2, padx=8, pady=4)

        ttk.Label(form, text="Output File", style="Muted.TLabel").grid(row=1, column=0, sticky="w", padx=8, pady=4)
        ttk.Entry(form, textvariable=self.output_var).grid(row=1, column=1, sticky="ew", padx=8, pady=4)
        ttk.Button(form, text="Save As", command=self.choose_output).grid(row=1, column=2, padx=8, pady=4)

        ttk.Label(form, text="Preset", style="Muted.TLabel").grid(row=2, column=0, sticky="w", padx=8, pady=4)
        ttk.Combobox(form, textvariable=self.preset_var, values=list(PRESETS.keys()), state="readonly").grid(
            row=2, column=1, sticky="ew", padx=8, pady=4
        )

        clip = ttk.Frame(form)
        clip.grid(row=3, column=1, sticky="ew", padx=8, pady=4)
        clip.grid_columnconfigure(1, weight=1)
        clip.grid_columnconfigure(3, weight=1)
        ttk.Label(form, text="Clip (optional)", style="Muted.TLabel").grid(row=3, column=0, sticky="w", padx=8, pady=4)
        ttk.Label(clip, text="Start").grid(row=0, column=0, padx=(0, 6))
        ttk.Entry(clip, textvariable=self.start_var).grid(row=0, column=1, sticky="ew", padx=(0, 12))
        ttk.Label(clip, text="Duration").grid(row=0, column=2, padx=(0, 6))
        ttk.Entry(clip, textvariable=self.length_var).grid(row=0, column=3, sticky="ew")

        self.progress = ttk.Progressbar(form, variable=self.progress_var, maximum=100.0)
        self.progress.grid(row=4, column=0, columnspan=3, sticky="ew", padx=8, pady=(8, 4))

        actions = ttk.Frame(form)
        actions.grid(row=5, column=0, columnspan=3, sticky="ew", padx=8, pady=(2, 6))
        self.start_btn = ttk.Button(actions, text="Start Conversion", command=self.start_conversion)
        self.start_btn.pack(side="left", padx=(0, 8))
        self.stop_btn = ttk.Button(actions, text="Stop", command=self.stop_conversion, state="disabled")
        self.stop_btn.pack(side="left", padx=8)
        ttk.Button(actions, text="Open Output Folder", command=self.open_output_folder).pack(side="left", padx=8)

        self.log_text = tk.Text(
            form,
            wrap="word",
            bg="#0d1f39",
            fg="#dbeafe",
            insertbackground="#dbeafe",
            relief="flat",
            highlightthickness=0,
            padx=10,
            pady=10,
            font=("DejaVu Sans Mono", 9),
        )
        self.log_text.grid(row=6, column=0, columnspan=3, sticky="nsew", padx=8, pady=(2, 8))

        ttk.Label(self, textvariable=self.status_var, style="Muted.TLabel").grid(row=2, column=0, sticky="ew", padx=18, pady=(0, 10))

    def choose_input(self) -> None:
        path = filedialog.askopenfilename(title="Choose Input Media")
        if not path:
            return
        self.input_var.set(path)
        if not self.output_var.get().strip():
            self.output_var.set(self.default_output(path))

    def choose_output(self) -> None:
        initial = self.output_var.get().strip()
        if not initial and self.input_var.get().strip():
            initial = self.default_output(self.input_var.get().strip())
        path = filedialog.asksaveasfilename(title="Choose Output File", initialfile=Path(initial).name if initial else "")
        if path:
            self.output_var.set(path)

    def default_output(self, input_path: str) -> str:
        src = Path(input_path)
        preset = self.preset_var.get()
        suffix = ".mp4"
        if preset.startswith("WebM"):
            suffix = ".webm"
        elif preset.startswith("MP3"):
            suffix = ".mp3"
        elif preset.startswith("GIF"):
            suffix = ".gif"
        return str(src.with_name(f"{src.stem}_converted{suffix}"))

    def append_log(self, line: str) -> None:
        self.log_text.insert(tk.END, line + "\n")
        self.log_text.see(tk.END)

    def start_conversion(self) -> None:
        if self.proc:
            return
        if shutil.which("ffmpeg") is None:
            messagebox.showerror("Missing ffmpeg", "ffmpeg is not installed or not in PATH.")
            return

        input_file = self.input_var.get().strip()
        output_file = self.output_var.get().strip()
        preset = self.preset_var.get()
        if not input_file:
            messagebox.showinfo("Input Required", "Choose an input file first.")
            return
        if not Path(input_file).exists():
            messagebox.showerror("Input Missing", "Input file does not exist.")
            return
        if not output_file:
            output_file = self.default_output(input_file)
            self.output_var.set(output_file)

        cmd = ["ffmpeg", "-hide_banner", "-y"]
        if self.start_var.get().strip():
            cmd.extend(["-ss", self.start_var.get().strip()])
        cmd.extend(["-i", input_file])
        if self.length_var.get().strip():
            cmd.extend(["-t", self.length_var.get().strip()])
        cmd.extend(PRESETS[preset])
        cmd.append(output_file)

        self.total_duration = ffprobe_duration(input_file)
        if self.length_var.get().strip():
            try:
                clip = float(self.length_var.get().strip())
                if clip > 0:
                    self.total_duration = min(self.total_duration, clip) if self.total_duration else clip
            except ValueError:
                pass

        self.log_text.delete("1.0", tk.END)
        self.append_log("Command: " + " ".join(cmd))
        self.progress_var.set(0.0)
        self.status_var.set("Conversion running...")

        self.proc = subprocess.Popen(
            cmd,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
        )
        self.start_btn.configure(state="disabled")
        self.stop_btn.configure(state="normal")

        self.worker = threading.Thread(target=self.read_process_output, daemon=True)
        self.worker.start()

    def read_process_output(self) -> None:
        assert self.proc is not None
        if self.proc.stderr is not None:
            for line in self.proc.stderr:
                self.log_queue.put(("log", line.rstrip()))
        rc = self.proc.wait()
        self.log_queue.put(("done", str(rc)))

    def stop_conversion(self) -> None:
        if not self.proc:
            return
        self.proc.terminate()
        self.status_var.set("Stopping conversion...")

    def poll_queue(self) -> None:
        while True:
            try:
                kind, payload = self.log_queue.get_nowait()
            except queue.Empty:
                break

            if kind == "log":
                self.append_log(payload)
                self.update_progress_from_line(payload)
            elif kind == "done":
                rc = int(payload)
                if rc == 0:
                    self.status_var.set("Conversion completed")
                    self.progress_var.set(100.0 if self.total_duration else self.progress_var.get())
                else:
                    self.status_var.set(f"Conversion failed (code {rc})")
                self.proc = None
                self.start_btn.configure(state="normal")
                self.stop_btn.configure(state="disabled")
        self.after(120, self.poll_queue)

    def update_progress_from_line(self, line: str) -> None:
        if self.total_duration <= 0:
            return
        match = TIME_RE.search(line)
        if not match:
            return
        elapsed = parse_timestamp(match.group(1))
        if elapsed <= 0:
            return
        percent = min(100.0, (elapsed / self.total_duration) * 100.0)
        self.progress_var.set(percent)

    def open_output_folder(self) -> None:
        output_file = self.output_var.get().strip()
        if output_file:
            folder = Path(output_file).expanduser().resolve().parent
        else:
            folder = Path.home()
        subprocess.Popen(["thunar", str(folder)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def main() -> int:
    app = MediaLab()
    app.mainloop()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
