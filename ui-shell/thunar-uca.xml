    <submenu></submenu>
    <unique-id>1700000000000001-1</unique-id>
    <command>crixa-wallpaper set %f</command>
    <description>Set selected image as desktop wallpaper</description>
    <range></range>
    <patterns>*.jpg;*.jpeg;*.png;*.webp;*.bmp;*.svg;</patterns>
    <directories/>
    <audio-files/>
    <image-files/>
    <other-files/>
    <text-files/>
    <video-files/>
